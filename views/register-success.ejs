<%- include('_head', { pageTitle: t.register.successTitle }) %>
<body class="pattern-bg min-h-screen flex flex-col">
  <%- include('_nav') %>

  <main class="flex-1 flex items-center justify-center px-4 py-16">
    <div class="max-w-md w-full text-center" style="background:white;border:1px solid var(--cream-dark);border-radius:16px;padding:48px 40px;">

      <!-- Icon -->
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full mb-6"
           style="background:var(--cream);">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--sage)"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="32" height="32">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>

      <h1 class="text-3xl font-medium mb-3" style="font-family:'Cormorant Garamond',serif;color:var(--earth);">
        <%= t.register.successTitle %>
      </h1>
      <p class="text-sm leading-relaxed mb-2" style="color:var(--earth-mid);">
        <%= t.register.successMessage %>
      </p>
      <p class="text-xs" style="color:var(--earth-light);">
        <%= t.register.pendingNote %>
      </p>

      <div class="flex flex-col sm:flex-row gap-3 mt-8 justify-center">
        <a href="/<%= lang %>/"
           class="px-6 py-3 rounded-lg text-sm font-medium"
           style="background:var(--earth);color:var(--cream);text-decoration:none;">
          <%= t.register.backHome %>
        </a>
        <a href="/<%= lang %>/sangomas"
           class="px-6 py-3 rounded-lg text-sm font-medium"
           style="background:white;color:var(--earth-mid);border:1px solid var(--cream-dark);text-decoration:none;">
          <%= t.register.browseSangomas %>
        </a>
      </div>
    </div>
  </main>

  <script src="/js/nav.js"></script>
</body>
